# ============================================
# RedRoomDigital API - Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/redroomdigital

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# AI (add your API key when ready)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
